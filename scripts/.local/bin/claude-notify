#!/usr/bin/env bash
# claude-notify <event-label>
#
# Claude Code Stop / Notification hook target. Reads the hook JSON on stdin
# and alerts that Claude finished or needs input:
#   - inside tmux: status-line message + terminal bell
#   - macOS desktop notification (terminal-notifier, else osascript)
# The current working directory (project) is shown so you know which checkout.
#
# Claude Code captures a hook's stdout, so we can't just print an escape to the
# terminal — the tmux cue uses tmux commands and the desktop alert uses
# terminal-notifier/osascript, neither of which relies on this process's stdout.
set -eo pipefail

label="${1:-Claude Code}"
# macOS notification sound name (see /System/Library/Sounds): Basso, Blow,
# Bottle, Frog, Funk, Glass, Hero, Morse, Ping, Pop, Purr, Sosumi, Submarine,
# Tink. Distinct sounds per event let you tell finished vs. needs-input by ear.
sound="${2:-Glass}"
payload="$(cat 2>/dev/null || true)"

# Stay silent when the session is already in front of you: Ghostty is the
# frontmost macOS app AND (in tmux) this pane's window is the active window of
# an attached session. lsappinfo is permission-free (unlike System Events).
is_session_focused() {
  local front
  front="$(lsappinfo front 2>/dev/null)" || return 1
  lsappinfo info -only name "$front" 2>/dev/null | grep -qi ghostty || return 1
  if [[ -n "${TMUX:-}" ]]; then
    [[ "$(tmux display-message -p -t "${TMUX_PANE:-}" '#{window_active}' 2>/dev/null)" == "1" ]] || return 1
    [[ "$(tmux display-message -p -t "${TMUX_PANE:-}" '#{session_attached}' 2>/dev/null)" -ge 1 ]] 2>/dev/null || return 1
  fi
  return 0
}
is_session_focused && exit 0

# Notification events carry a human-readable .message; Stop does not.
body="$(printf '%s' "$payload" | jq -r '.message // empty' 2>/dev/null || true)"
[[ -n "$body" ]] || body="Ready for input"

# Which checkout — the cwd basename (full path on the tmux status line).
proj="$(basename "$PWD")"

# macOS desktop notification
if command -v terminal-notifier >/dev/null 2>&1; then
  terminal-notifier -title "$label" -subtitle "$proj" -message "$body" -sound "$sound" >/dev/null 2>&1 || true
elif command -v osascript >/dev/null 2>&1; then
  osascript -e "display notification \"${body//\"/\\\"}\" with title \"${label//\"/\\\"}\" subtitle \"${proj//\"/\\\"}\" sound name \"${sound//\"/\\\"}\"" >/dev/null 2>&1 || true
fi

exit 0
