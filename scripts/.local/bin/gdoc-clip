#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "markdown",
# ]
# ///
"""gdoc-clip: reformat clipboard markdown into Google-Docs-pasteable rich text.

Reads the current clipboard as markdown, converts it to HTML, and writes it
back to the clipboard as rich (HTML) content with the original markdown kept
as the plain-text fallback. Paste (Cmd+V) into a Google Doc and headings,
bold, lists, links, and code render as real formatting instead of raw
markdown syntax.

macOS only (uses pbpaste + osascript to set clipboard formats).

Usage:
    gdoc-clip            # convert clipboard in place
    gdoc-clip --html     # print the generated HTML instead of touching the clipboard
"""

import argparse
import re
import subprocess
import sys
import tempfile
from pathlib import Path

import markdown as md

APPLESCRIPT = """
on run argv
    set htmlPath to item 1 of argv
    set txtPath to item 2 of argv
    set htmlData to read (POSIX file htmlPath) as «class HTML»
    set plainData to read (POSIX file txtPath) as «class utf8»
    set the clipboard to {«class HTML»:htmlData, string:plainData}
end run
"""


LIST_ITEM = re.compile(r"^\s*([-*+]|\d+\.)\s+")


def normalize_lists(text: str) -> str:
    """Insert the blank line python-markdown requires before a list.

    Markdown like `**Label**\n- item` keeps the hyphens as literal paragraph
    text, which Google Docs' markdown auto-detection then re-interprets on
    paste — swallowing following code-block lines into the list.
    Fenced code blocks are left untouched.
    """
    out = []
    in_fence = False
    prev = ""
    for line in text.splitlines():
        if line.lstrip().startswith("```"):
            in_fence = not in_fence
        elif not in_fence and LIST_ITEM.match(line) and prev.strip() and not LIST_ITEM.match(prev):
            out.append("")
        out.append(line)
        prev = line
    return "\n".join(out)


CODE_BLOCK = re.compile(r"<pre><code[^>]*>(.*?)</code></pre>", re.DOTALL)


def code_block_as_table(match: re.Match) -> str:
    """Render a fenced code block as a single-cell table.

    Google Docs' paste handler doesn't treat <pre> as a solid block: when a
    list precedes it, the code lines get absorbed into the open list and
    each line grows a bullet. A table cell can't be merged into a list.
    """
    code = match.group(1).rstrip("\n").replace("\n", "<br>")
    return (
        '<table style="border-collapse: collapse; width: 100%;"><tr>'
        '<td style="border: 1px solid #d0d0d0; background-color: #f6f8fa; padding: 8px;'
        ' font-family: \'Courier New\', monospace; font-size: 10pt;">'
        f"{code}</td></tr></table>"
    )


def markdown_to_html(text: str) -> str:
    body = md.markdown(normalize_lists(text), extensions=["fenced_code", "tables", "sane_lists"])
    body = CODE_BLOCK.sub(code_block_as_table, body)
    body = body.replace("<code>", "<code style=\"font-family: 'Courier New', monospace;\">")
    return f'<html><head><meta charset="utf-8"></head><body>{body}</body></html>'


def main():
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--html", action="store_true", help="Print generated HTML instead of writing the clipboard")
    args = parser.parse_args()

    if sys.platform != "darwin":
        sys.exit("gdoc-clip only supports macOS (pbpaste/osascript).")

    markdown_text = subprocess.run(["pbpaste"], capture_output=True, text=True, check=True).stdout
    if not markdown_text.strip():
        sys.exit("Clipboard is empty.")

    html = markdown_to_html(markdown_text)

    if args.html:
        print(html)
        return

    with tempfile.TemporaryDirectory() as tmp:
        html_path = Path(tmp) / "clip.html"
        txt_path = Path(tmp) / "clip.txt"
        html_path.write_text(html)
        txt_path.write_text(markdown_text)

        subprocess.run(
            ["osascript", "-", str(html_path), str(txt_path)],
            input=APPLESCRIPT,
            text=True,
            check=True,
        )

    print("Clipboard is now Google-Docs-ready — paste with Cmd+V.")


if __name__ == "__main__":
    main()
