{
  "permissions": {
    "allow": [
      "mcp__honcho",
      "Bash(cd *)",
      "Bash(hmt *)"
    ],
    "ask": [
      "Bash(git push:*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh working"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh waiting"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/claude-notify 'Claude needs input' Submarine",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh waiting"
          },
          {
            "type": "command",
            "command": "jq -r \".tool_input.command\" | grep -qE \"git[[:space:]]+push([[:space:]]|$).*(--force|--force-with-lease|(^|[[:space:]])-f([[:space:]]|$))\" && printf '%s' \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"permissionDecision\\\":\\\"deny\\\",\\\"permissionDecisionReason\\\":\\\"Force-push is reserved for Richard. Finish all prep (commit, rebase, fetch, verify the lease), then STOP and ask him to run the force-push himself; do not run it.\\\"}}\" || true",
            "statusMessage": "Checking for force-push"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/plugins/tmux-claude-session-manager/scripts/state.sh idle"
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/claude-notify 'Claude finished' Glass",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/statusline-dense.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "tui": "fullscreen"
}
