eval "$(/opt/homebrew/bin/brew shellenv)"
eval "$(/usr/libexec/path_helper)"

# The next line updates PATH for the Google Cloud SDK.
if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/google-cloud-sdk/path.zsh.inc"; fi

# The next line enables shell command completion for gcloud.
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/google-cloud-sdk/completion.zsh.inc"; fi

[ -f '/opt/homebrew/opt/chruby/share/chruby/chruby.sh' ] && source /opt/homebrew/opt/chruby/share/chruby/chruby.sh
[ -f '/opt/homebrew/opt/chruby/share/chruby/auto.sh' ] && source /opt/homebrew/opt/chruby/share/chruby/auto.sh

export ICLOUD="$HOME/Library/Mobile Documents/com~apple~CloudDocs"
export IN="$HOME/Documents/Brain/Inbox"
export DEV0="$HOME/Documents/Developer"
export DEV="$HOME/proj"
export NOTES="$HOME/notes"
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh

export JAVA_HOME=$(brew --prefix java)
export PATH=$JAVA_HOME/bin:$PATH
export SPARK_HOME=$(brew --prefix apache-spark)/libexec
export PATH=$SPARK_HOME/bin:$PATH
export PATH=$HOME/.cargo/env:$PATH
export PATH=$PATH:"$HOME/texpresso/build"
export PATH=$PATH:"$HOME/kanata"
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH:$HOME/mongodb/bin"
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"
export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"

# This ensures the use of gsed instead of the mac version of sed
export PATH="/opt/homebrew/opt/gnu-sed/libexec/gnubin:$PATH"
# alias sed='gsed'
# alias find='gfind'
# alias perf='gperf'
# alias awk='gawk'
help() { 
    args="$@"
    bash -c "help $args" 2> /dev/null

    # Fallback to zsh
    if [[ $? -ne 0 ]]; then
        run-help "$args"
    fi
}
lman() { man -M ~/linux-man "$@" }

rpi() {
    # If tailscale exists (virtual networks as utun*), use it directly,
    # otherwise will require password
    if ifconfig | grep '^utun' >/dev/null 2>&1; then
        ssh rpi
    else
        if command -v op >/dev/null 2>&1; then
            pass=$(op item get RPI --reveal --fields label=password)
            sshpass -f <(printf '%s\n' "$pass") ssh rpi
        else
            echo "1Password cli not found, install it first."
        fi
    fi
}

rpp() {
    if command -v op >/dev/null 2>&1; then
        pass=$(op item get RPI --reveal --fields label=password)
        echo "$pass" | pbcopy
        echo "Copied to clipboard"
    else
        echo "1Password cli not found, install it first."
    fi
}

export SNVIM="$DEV/cont/neovim"
export BOOKS="$HOME/Documents/Books"
export PATH="/opt/homebrew/bin:$PATH"

# The following lines have been added by Docker Desktop to enable Docker CLI completions.
fpath=(/Users/richard.penabonifaz/.docker/completions $fpath)
autoload -Uz compinit
compinit
# End of Docker CLI completions
#
